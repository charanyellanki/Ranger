# ─── Ranger environment ─────────────────────────────────────────────
# Copy this file to `.env` and fill in the blanks. Never commit `.env`.

# ─── Postgres ──────────────────────────────────────────────────────
POSTGRES_USER=ranger
POSTGRES_PASSWORD=ranger
POSTGRES_DB=ranger

# ─── Encryption ─────────────────────────────────────────────────────
# Fernet key used to encrypt LLM provider API keys at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: If this key changes, all previously stored API keys become
# undecryptable. Back it up the same way you'd back up a database password.
RANGER_ENCRYPTION_KEY=

# ─── Admin auth (dev-only shared token) ─────────────────────────────
# Sent as the `X-Admin-Token` header from the frontend admin pages.
ADMIN_TOKEN=change-me-dev-only

# ─── API <-> frontend ───────────────────────────────────────────────
# CORS origins the api service accepts. Comma-separated.
CORS_ORIGINS=http://localhost:5173

# Base URL the frontend uses to reach the api service (baked in at build time).
VITE_API_URL=http://localhost:8000

# ─── Observability ──────────────────────────────────────────────────
LOG_LEVEL=INFO
